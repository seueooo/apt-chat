# syntax=docker/dockerfile:1.7
# Build context: monorepo root (..)
# Build command:
#   docker compose -f deploy/docker-compose.yml build web
#
# Next.js 16 with output: "standalone" in apps/web/next.config.ts.
# Verified standalone structure for this pnpm workspace (apps/web/):
#   .next/standalone/apps/web/server.js          <- entry
#   .next/standalone/apps/web/.next/             <- server chunks
#   .next/standalone/apps/web/node_modules/      <- web-local hoist
#   .next/standalone/node_modules/               <- shared hoist (next, react, ...)
#   (static + public must be copied manually per Next docs)

########## deps ##########
FROM node:20-alpine AS deps

RUN apk add --no-cache libc6-compat \
    && corepack enable \
    && corepack prepare pnpm@9.4.0 --activate

WORKDIR /repo

# Workspace manifest files only, for a cache-friendly install layer.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/package.json

RUN pnpm install --frozen-lockfile

########## build ##########
FROM node:20-alpine AS build

RUN apk add --no-cache libc6-compat \
    && corepack enable \
    && corepack prepare pnpm@9.4.0 --activate

ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production

WORKDIR /repo

# Reuse node_modules from deps stage.
COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/apps/web/node_modules ./apps/web/node_modules

# Copy only what's needed for the build (avoid copying apps/server/, apps/etl/, etc).
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web ./apps/web

RUN pnpm --filter web build

########## runner ##########
FROM node:20-alpine AS runner

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    API_URL=http://server:8000

WORKDIR /app

RUN addgroup -S app && adduser -S app -G app

# Standalone bundle (entry + hoisted node_modules at /app root).
COPY --from=build --chown=app:app /repo/apps/web/.next/standalone/ ./

# Static assets not copied by Next automatically (per output: standalone docs).
COPY --from=build --chown=app:app /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=app:app /repo/apps/web/public ./apps/web/public

USER app

EXPOSE 3000

# server.js lives inside apps/web/ because the workspace path is preserved in standalone.
WORKDIR /app/apps/web
CMD ["node", "server.js"]
